{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && uv run --no-sync .claude/hooks/guard-uv-only.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && uv run --no-sync .claude/hooks/guard-data-readonly.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && uv run --no-sync .claude/hooks/route-exploration.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && uv run --no-sync .claude/hooks/check-new-file-size.py",
            "timeout": 15,
            "statusMessage": "Checking new file size..."
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && FILE=$(python3 -c \"import json,sys;d=json.load(sys.stdin);print(d.get('tool_result',{}).get('filePath') or d.get('tool_input',{}).get('file_path',''))\") && echo \"$FILE\" | grep -q '\\.py$' && uv run ruff format \"$FILE\" 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Formatting Python file..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'git diff --name-only HEAD | grep -qE \"\\.(py)$\" && node .gitnexus/run.cjs analyze || true'",
            "timeout": 120,
            "statusMessage": "Refreshing GitNexus index..."
          },
          {
            "type": "command",
            "command": "bash -c 'git diff --name-only HEAD | grep -vE \"^knowledge/graphify-out/\" | grep -qE \"^knowledge/\" && graphify update knowledge/ || true'",
            "timeout": 120,
            "statusMessage": "Refreshing Graphify literature graph (knowledge/ only)..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "academic-research-skills@academic-research-skills": true,
    "caveman@caveman": true,
    "superpowers@claude-plugins-official": true
  }
}
